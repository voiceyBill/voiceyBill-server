# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
BASE_PATH=/api

# ─── Database ─────────────────────────────────────────────────────────────────
# Get your free MongoDB Atlas cluster at https://www.mongodb.com/atlas
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=monetra

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use a long random string — e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_strong_jwt_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_strong_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
# Used for: receipt scanning, voice transaction classification
GEMINI_API_KEY=your_gemini_api_key_here

# ─── UpliftAI (Voice Transcription) ───────────────────────────────────────────
# Get your key at https://upliftai.org
# Used for: speech-to-text from voice recordings
UPLIFT_AI_API_KEY=your_upliftai_api_key_here

# ─── Cloudinary (Image Storage) ───────────────────────────────────────────────
# Get your credentials at https://cloudinary.com (free tier available)
# Used for: profile photos, receipt images
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Resend (Email) ───────────────────────────────────────────────────────────
# Get your key at https://resend.com (free tier available)
# Used for: monthly report emails
# Requires a verified domain — leave blank to disable email reports
RESEND_API_KEY=your_resend_api_key_here
RESEND_MAILER_SENDER=noreply@yourdomain.com
